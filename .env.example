# App
NODE_ENV=development
APP_URL=http://localhost:5173
API_URL=http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000
API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
DATABASE_URL=mysql+pymysql://labelhub:labelhub@localhost:3306/labelhub

# Auth
SESSION_SECRET=change-me-in-local-env
SESSION_COOKIE_NAME=labelhub_session
SESSION_COOKIE_SECURE=false
SESSION_MAX_AGE_SECONDS=28800

# Queue
REDIS_URL=redis://localhost:6379

# System Agent
SYSTEM_AGENT_TOKEN=dev-system-agent-token
AGENT_WORKER_ID=labelhub-agent-local
AGENT_POLL_INTERVAL_SECONDS=5
REVIEW_JOB_LOCK_TIMEOUT_SECONDS=300

# OpenAI API format LLM provider. Do not commit real keys.
# Agent reads BASE_URL / MODEL_NAME first, and still accepts OPENAI_BASE_URL / OPENAI_MODEL as aliases.
OPENAI_API_KEY=
BASE_URL=https://your-openai-compatible-provider/v1
MODEL_NAME=your-model-name
# Large compatible models can exceed short HTTP defaults on cold start or slow responses.
OPENAI_TIMEOUT_SECONDS=90
# Optional OpenAI-compatible request extension. Keep empty for providers that reject extra fields.
LLM_EXTRA_BODY_JSON=
