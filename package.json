{
  "name": "labelhub",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "description": "LabelHub 数据标注平台 monorepo。",
  "type": "module",
  "scripts": {
    "dev:web": "pnpm --filter @labelhub/web dev",
    "build:web": "pnpm --filter @labelhub/web build",
    "test:web": "pnpm --filter @labelhub/web test",
    "lint:web": "pnpm --filter @labelhub/web lint",
    "typecheck:web": "pnpm --filter @labelhub/web typecheck",
    "format": "pnpm -r format"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
